{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "joranski/filament-live-chat",
    "version": "0.1.0",
    "description": "Record-scoped live coordination for Filament — polling, presence, and promote-to-comments bridge",
    "keywords": [
        "laravel",
        "filament",
        "livewire",
        "chat",
        "collaboration"
    ],
    "license": "MIT",
    "type": "library",
    "require": {
        "php": "^8.3",
        "filament/filament": "^5.0",
        "illuminate/contracts": "^12.0 || ^13.0",
        "illuminate/database": "^12.0 || ^13.0",
        "illuminate/support": "^12.0 || ^13.0",
        "joranski/filament-comments": "^0.1",
        "livewire/livewire": "^4.0",
        "livewire/flux-pro": "^2.0",
        "spatie/laravel-package-tools": "^1.16"
    },
    "require-dev": {
        "orchestra/testbench": "^10.0 || ^11.0",
        "pestphp/pest": "^4.0",
        "pestphp/pest-plugin-laravel": "^4.0"
    },
    "autoload": {
        "psr-4": {
            "Joranski\\FilamentLiveChat\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Joranski\\FilamentLiveChat\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Joranski\\FilamentLiveChat\\FilamentLiveChatServiceProvider"
            ]
        }
    },
    "scripts": {
        "test": "pest --compact"
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    }
}
